{
  "name": "my-slides",
  "version": "1.0.0",
  "description": "Marp slide template",
  "scripts": {
    "dev": "node scripts/marp-timed.mjs --engine ./engine.mjs --theme style.css --input-dir slides -o html -w",
    "preview": "marp --engine ./engine.mjs --theme style.css --input-dir slides -s",
    "build": "node scripts/marp-timed.mjs --engine ./engine.mjs --theme style.css --input-dir slides -o html",
    "build:pdf": "node scripts/marp-timed.mjs --engine ./engine.mjs --theme style.css --input-dir slides -o pdf --pdf",
    "build:pptx": "node scripts/marp-timed.mjs --engine ./engine.mjs --theme style.css --input-dir slides -o pptx --pptx"
  },
  "keywords": ["marp", "slides", "presentation"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@marp-team/marp-cli": "^4.3.1",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-mark": "^4.0.0"
  }
}
